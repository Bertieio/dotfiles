alias python=python3
alias pip=pip3
alias ls='ls --color=auto'
alias ll='1s -l'
alias la='ls -a'
export PS1="\[\033[38;5;14m\]\A \d \u\[$(tput sgr0)\]\[\033[38;5;15m\]@\[$(tput sgr0)\]\[\033[38;5;14m\]\h \[$(tput bold)\]\w\[$(tput sgr0)\]\[$(tput sgr0)\]\[\033[38;5;15m\] \[$(tput sgr0)\]\[\033[38;5;14m\]\\$>\[$(tput sgr0)\]"
export TERM=xterm-256color
