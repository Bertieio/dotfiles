alias python=python3
alias pip=pip3
alias minecraft="sh ~/Desktop/FeedTheBeastServer/ServerStart.sh"
alias ls='ls --color=auto'

PS1='\[$(tput setaf 6)\]\t \[$(tput setaf 2)\][\[$(tput setaf 3)\]\u\[$(tput setaf 7)\]@\[$(tput setaf 1)\]\h \[$(tput setaf 6)\]\W\[$(tput setaf 2)\]]\[$(tput setaf 4)\]\\$ \[$(tput sgr0)\]'

export TERM=xterm-256color
